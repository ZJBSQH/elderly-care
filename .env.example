# ============================================================
# 老年护理云平台 - 环境变量配置
# 使用方式: 复制此文件为 .env，修改下方配置值
#   cp .env.example .env
# ============================================================

# ============================================================
# 开发环境默认值（所有组员统一使用，生产环境请修改）
# ============================================================

# MySQL 数据库
MYSQL_ROOT_PASSWORD=dev123
MYSQL_PORT=13306

# 业务数据库连接 (所有微服务共用)
DB_HOST=localhost
DB_PORT=13306
DB_USER=root
DB_PASSWORD=dev123

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT 配置 (生产环境务必更换为随机强密钥)
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRATION=86400000

# Nacos 配置 (开发环境默认关闭认证，无需修改)
# NACOS_AUTH_ENABLE=false
# NACOS_AUTH_TOKEN=
# NACOS_AUTH_IDENTITY_KEY=
# NACOS_AUTH_IDENTITY_VALUE=
