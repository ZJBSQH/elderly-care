<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.elderlycare.medicine.mapper.MedicineMapper">
    <select id="selectByElderId" resultType="com.elderlycare.medicine.entity.Medicine">
        SELECT * FROM medicine WHERE elder_id = #{elderId} ORDER BY remind_time ASC
    </select>
</mapper>
