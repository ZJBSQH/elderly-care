<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.elderlycare.user.mapper.FamilyMapper">

    <select id="selectByFamilyUserId" resultType="com.elderlycare.user.entity.Family">
        SELECT * FROM family
        WHERE family_user_id = #{familyUserId}
          AND bind_status = 1
    </select>

    <select id="selectByElderId" resultType="com.elderlycare.user.entity.Family">
        SELECT * FROM family
        WHERE elder_id = #{elderId}
          AND bind_status = 1
    </select>

</mapper>
