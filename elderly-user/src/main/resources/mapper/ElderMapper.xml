<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.elderlycare.user.mapper.ElderMapper">

    <select id="selectByUserId" resultType="com.elderlycare.user.entity.Elder">
        SELECT * FROM elder
        WHERE user_id = #{userId}
        LIMIT 1
    </select>

</mapper>
